# Level 2: Data Lake
# + MinIO + Delta Lake + JupyterLab - object storage, lakehouse, notebooks
# Cost: $50-150/month | Data: < 1 TB
# Upgrade when: need distributed processing or federated queries

INCLUDE_POSTGRES=true
INCLUDE_DAGSTER=true
INCLUDE_SUPERSET=true
INCLUDE_DBT=true
INCLUDE_KYROS=true
INCLUDE_PORTAINER=true
INCLUDE_MINIO=true
INCLUDE_CLOUDBEAVER=true
INCLUDE_JUPYTERLAB=true
INCLUDE_GRAFANA=true
INCLUDE_LOKI=true
INCLUDE_PROMTAIL=true
INCLUDE_TRINO=false
INCLUDE_KAFKA=false
INCLUDE_FLINK=false
INCLUDE_CODE_SERVER=true
INCLUDE_SQLPAD=false

WORKERS=0

SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=2G
SPARK_EXECUTOR_MEMORY=2G
SPARK_WORKER_CORES=2
SPARK_EXECUTOR_CORES=2

# Database
POSTGRES_USER=kyros
POSTGRES_PASSWORD=kyros_dev

# MinIO
MINIO_ROOT_USER=kyros
MINIO_ROOT_PASSWORD=kyros_dev

# Superset
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=admin
SUPERSET_SECRET_KEY=ChangeMeToARandomString

# Dagster
DAGSTER_WORKSPACE=kyros
INCLUDE_TRAEFIK=false
