# Level 4: Enterprise
# + Kafka + Flink + SSO - full platform capabilities, streaming
# Cost: $500+/month | Data: Any scale
# This is full capability - use what you need

INCLUDE_POSTGRES=true
INCLUDE_DAGSTER=true
INCLUDE_SUPERSET=true
INCLUDE_DBT=true
INCLUDE_KYROS=true
INCLUDE_PORTAINER=true
INCLUDE_MINIO=true
INCLUDE_CLOUDBEAVER=true
INCLUDE_JUPYTERLAB=true
INCLUDE_GRAFANA=true
INCLUDE_TRINO=true
INCLUDE_KAFKA=true
INCLUDE_FLINK=true
INCLUDE_CODE_SERVER=true
INCLUDE_SQLPAD=false

# Spark cluster
WORKERS=3

SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=4G
SPARK_EXECUTOR_MEMORY=4G
SPARK_WORKER_CORES=4
SPARK_EXECUTOR_CORES=4

# Database
POSTGRES_USER=kyros
POSTGRES_PASSWORD=kyros_dev

# MinIO
MINIO_ROOT_USER=kyros
MINIO_ROOT_PASSWORD=kyros_dev

# Superset
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=admin
SUPERSET_SECRET_KEY=ChangeMeToARandomString

# Dagster
DAGSTER_WORKSPACE=kyros

# Keycloak (if using SSO)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
