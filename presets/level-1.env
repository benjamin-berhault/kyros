# Level 1: Team
# + PostgreSQL + Dagster + Superset - shared database, orchestration, dashboards
# Cost: $20-100/month | Data: < 500 GB
# Upgrade when: need object storage, notebooks, or data lake capabilities

INCLUDE_POSTGRES=true
INCLUDE_DAGSTER=true
INCLUDE_SUPERSET=true
INCLUDE_DBT=true
INCLUDE_KYROS=true
INCLUDE_PORTAINER=true
INCLUDE_MINIO=false
INCLUDE_CLOUDBEAVER=true
INCLUDE_JUPYTERLAB=false
INCLUDE_GRAFANA=false
INCLUDE_LOKI=false
INCLUDE_PROMTAIL=false
INCLUDE_TRINO=false
INCLUDE_KAFKA=false
INCLUDE_FLINK=false
INCLUDE_CODE_SERVER=false
INCLUDE_SQLPAD=true

WORKERS=0

SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=1G
SPARK_EXECUTOR_MEMORY=1G
SPARK_WORKER_CORES=1
SPARK_EXECUTOR_CORES=1

# Database
POSTGRES_USER=kyros
POSTGRES_PASSWORD=kyros_dev

# Superset
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=admin
SUPERSET_SECRET_KEY=ChangeMeToARandomString

# Dagster
DAGSTER_WORKSPACE=kyros
