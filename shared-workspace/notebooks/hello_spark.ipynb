   "source": [
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql.functions import col, expr, concat, lit, transform\n",
    "\n",
    "# Initialize SparkSession\n",
    "spark = (SparkSession.builder\n",
    "         .appName(\"test-spark-config\")\n",
    "         .master(\"spark://spark-master:7077\")  # Replace with your master URL if different\n",
    "         .config(\"spark.executor.memory\", \"512m\")\n",
    "         .getOrCreate())\n",
    "\n",
    "# Set log level to ERROR to minimize logs\n",
    "spark.sparkContext.setLogLevel(\"ERROR\")\n",
    "\n",
    "# Sample Data\n",
    "data = [\n",
    "    (\"John\", 28),\n",
    "    (\"Jane\", 23),\n",
    "    (\"Sam\", 34),\n",
    "    (\"Anna\", 45)\n",
    "]\n",
    "\n",
    "# Create DataFrame\n",
    "df = spark.createDataFrame(data, [\"Name\", \"Age\"])\n",
    "\n",
    "# Show the DataFrame\n",
    "print(\"DataFrame:\")\n",
    "df.show()\n",
    "\n",
    "# Perform a basic transformation\n",
    "df_filtered = df.filter(col(\"Age\") > 30)\n",
    "\n",
    "# Show the filtered DataFrame\n",
    "print(\"Filtered DataFrame (Age > 30):\")\n",
    "df_filtered.show()\n",
    "\n",
    "# Stop the Spark session\n",
    "spark.stop()\n"
   ]
  },
