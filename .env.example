# Kyros Environment Configuration
# Copy this file to .env and customize values
# NEVER commit .env to version control

# ============================================
# Component Selection (true/false)
# ============================================
INCLUDE_POSTGRES=true
INCLUDE_DAGSTER=true
INCLUDE_SUPERSET=true
INCLUDE_DBT=true
INCLUDE_KYROS=true
INCLUDE_PORTAINER=true
INCLUDE_MINIO=false
INCLUDE_CLOUDBEAVER=true
INCLUDE_JUPYTERLAB=false
INCLUDE_GRAFANA=false
INCLUDE_TRINO=false
INCLUDE_KAFKA=false
INCLUDE_FLINK=false
INCLUDE_CODE_SERVER=false
INCLUDE_SQLPAD=true

# ============================================
# Spark Configuration
# ============================================
WORKERS=0
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=1G
SPARK_EXECUTOR_MEMORY=1G
SPARK_WORKER_CORES=1
SPARK_EXECUTOR_CORES=1

# ============================================
# Database Credentials
# IMPORTANT: Change these in production!
# ============================================
POSTGRES_USER=kyros
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ============================================
# Superset Configuration
# IMPORTANT: Change these in production!
# ============================================
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=CHANGE_ME_IN_PRODUCTION
SUPERSET_SECRET_KEY=GENERATE_A_RANDOM_STRING_HERE

# ============================================
# MinIO Configuration (S3-compatible storage)
# IMPORTANT: Change these in production!
# ============================================
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ============================================
# Portainer Configuration
# IMPORTANT: Change these in production!
# ============================================
PORTAINER_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ============================================
# Dagster
# ============================================
DAGSTER_WORKSPACE=kyros

# ============================================
# Optional: Local Registry (for air-gapped environments)
# ============================================
# IF_USING_LOCAL_REGISTRY=localhost:5000/
