# Create the necessary directories
RUN mkdir -p /opt/spark/sbin /opt/spark/bin /opt/spark/logs

# Replace the sbin and bin directories with symbolic links
RUN rm -rf /opt/spark/sbin && \
    rm -rf /opt/spark/bin && \
    ln -s /opt/bitnami/spark/sbin /opt/spark/sbin && \
    ln -s /opt/bitnami/spark/bin /opt/spark/bin

# Set ownership of logs directory
RUN chown -R 1001:1001 /opt/spark/logs

