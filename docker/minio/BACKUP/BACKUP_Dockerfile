# Use Alpine as the base image for a lightweight environment
FROM alpine:3.18

# Install MinIO, Nginx, and curl
RUN apk --no-cache add curl nginx && \
    curl -O https://dl.min.io/server/minio/release/linux-amd64/minio && \
    chmod +x minio && \
    mv minio /usr/local/bin/minio

# Set MinIO Access Key and Secret Key (replace with your actual keys)
ENV MINIO_ACCESS_KEY=minioadmin
ENV MINIO_SECRET_KEY=minioadmin

# Create the Hadoop configuration directory
RUN mkdir -p /etc/hadoop/conf

# Copy the Hadoop configuration files into the container
COPY core-site.xml /etc/hadoop/conf/core-site.xml

# Copy the main Nginx configuration and server block configuration
COPY nginx.conf /etc/nginx/nginx.conf
COPY default.conf /etc/nginx/conf.d/default.conf

# Copy the entrypoint script to manage both services
COPY entrypoint.sh /usr/local/bin/entrypoint.sh

# Make the entrypoint script executable
RUN chmod +x /usr/local/bin/entrypoint.sh

# Expose the necessary ports
EXPOSE 9000 9001 9003

# Use the entrypoint script to run both MinIO and Nginx
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
