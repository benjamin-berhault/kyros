ARG BASE_IMAGE=jupyter/base-notebook:latest
FROM ${BASE_IMAGE}

# -- Layer: Image Metadata

ARG build_date

LABEL org.label-schema.build-date=${build_date}
LABEL org.label-schema.name="Data Engineering with Apache Spark and Delta Lake Cookbook - JupyterLab Image"
LABEL org.label-schema.description="JupyterLab image"

# Switch to root to install necessary packages
USER root

# Install Java (required for dbt-spark even if not using Spark directly)
RUN apt-get update && apt-get install -y \
    openjdk-11-jdk \
    build-essential \
    cmake \
    llvm \
    libclang-dev \
    curl \
    golang-go \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Rust and Cargo (Rust's package manager)
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"  

# Ensure directory exists and has correct permissions
RUN mkdir -p /home/jovyan/.local/share/jupyter/runtime && \
    chown -R jovyan:users /home/jovyan/.local/share/jupyter

# Install Jupyter Kernels for C++, Rust, and Go

# Install C++ kernel (xeus-cling)
RUN conda install -c conda-forge xeus-cling -y

# Install Go kernel (gophernotes)
RUN go install github.com/gopherdata/gophernotes@latest
RUN mkdir -p ~/.local/share/jupyter/kernels/gophernotes
RUN cp $(go env GOPATH)/pkg/mod/github.com/gopherdata/gophernotes@*/kernel/* ~/.local/share/jupyter/kernels/gophernotes/

# Install Rust kernel (evcxr)
# Ensure PATH is set for the cargo command
RUN /bin/bash -c "source $HOME/.cargo/env && cargo install evcxr_jupyter"
RUN /bin/bash -c "source $HOME/.cargo/env && evcxr_jupyter --install"

# Switch back to the original user (jovyan for Jupyter base images)
USER ${NB_USER}

# -- Layer: JupyterLab + dbt for PostgreSQL and Parquet

# Define build arguments with default values
ARG jupyterlab_version=3.0.16

RUN pip3 install --no-cache-dir wget==3.2 \
    jupyterlab==${jupyterlab_version} \
    dbt-core \
    dbt-postgres \
    dbt-spark[PySpark] 
# Additional dbt plugins for other databases can be installed here:
# RUN pip3 install dbt-bigquery dbt-snowflake dbt-redshift etc.

ENV JAVA_HOME /usr/lib/jvm/java-11-openjdk-amd64
ENV PATH $JAVA_HOME/bin:$PATH

# Expose JupyterLab port
EXPOSE 8888

# Set the working directory
WORKDIR ${SHARED_WORKSPACE}

# Start JupyterLab
CMD jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --allow-root --NotebookApp.token=
