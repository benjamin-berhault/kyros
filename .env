# .env
IF_USING_LOCAL_REGISTRY=
BASE_URL_JARS=https://

INCLUDE_MKDOCS=true
INCLUDE_JUPYTERLAB=true
INCLUDE_JUPYTERLAB_CPP_SUPPORT=false
INCLUDE_JUPYTERLAB_GO_SUPPORT=false
INCLUDE_JUPYTERLAB_RUST_SUPPORT=false
INCLUDE_JUPYTERLAB_DBT_SUPPORT=false
INCLUDE_JUPYTERLAB_DBT_POSTGRES_SUPPORT=false
INCLUDE_JUPYTERLAB_DBT_SPARK_SUPPORT=false
INCLUDE_CLOUDBEAVER=true
INCLUDE_SQLPAD=false
INCLUDE_CODE_SERVER=true
INCLUDE_KYROS=true
INCLUDE_KAFKA=false
INCLUDE_MINIO=true
INCLUDE_PORTAINER=true
INCLUDE_TRINO=true
INCLUDE_DAGSTER=true
INCLUDE_DBT=true
INCLUDE_FLINK=false
INCLUDE_GRAFANA=false
WORKERS=2
HIVE_VERSION=4.0.0


SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077

# Memory settings
SPARK_WORKER_MEMORY=1G
SPARK_EXECUTOR_MEMORY=1G

# CPU core settings
SPARK_WORKER_CORES=2
SPARK_EXECUTOR_CORES=2

# Dagster workspace
DAGSTER_WORKSPACE=try-dagster